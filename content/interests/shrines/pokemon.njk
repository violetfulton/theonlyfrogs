---
title: Violet's PC
layout: layouts/pokeBase.njk
customcss: "/assets/css/shrines/pokemon/home.css"
permalink: /shrines/pokemon/
---

<section class="pc-hero">
  <p class="pc-kicker">Accessed VIOLET's PC!</p>
  <h1>Pokémon Shrine</h1>
  <p class="pc-hero__text">
    Welcome to my little Pokémon storage system — shinies, trainer memories, physical collection bits,
    Hall of Fame teams, and whatever hunt I am currently obsessing over.
  </p>

  <div class="pc-status-grid" aria-label="Pokémon shrine status">
    <article class="pc-status-card">
      <span class="pc-status-card__label">Latest sparkle</span>
      {% if pokemonShinies.stats.latest %}
        <strong>{{ pokemonShinies.stats.latest.nickname or pokemonShinies.stats.latest.species }}</strong>
        <small>{{ pokemonShinies.stats.latest.originGame }}</small>
      {% else %}
        <strong>Coming soon</strong>
        <small>add shinies to the sheet</small>
      {% endif %}
    </article>

    <article class="pc-status-card">
      <span class="pc-status-card__label">Shiny log</span>
      <strong>{{ pokemonShinies.stats.total or 0 }}</strong>
      <small>published captures</small>
    </article>

    <article class="pc-status-card">
      <span class="pc-status-card__label">Unique species</span>
      <strong>{{ pokemonShinies.stats.unique or 0 }}</strong>
      <small>forms included</small>
    </article>

    <article class="pc-status-card">
      <span class="pc-status-card__label">Current goal</span>
      <strong>Safari Week</strong>
      <small>prep mode activated</small>
    </article>
  </div>
</section>

<section class="pc-section">
  <div class="pc-section__heading">
    <p class="pc-kicker">Main storage</p>
    <h2>Choose a box</h2>
  </div>

  <div class="pc-box-grid">
    <a class="pc-box-card pc-box-card--trainer" href="/shrines/pokemon/me/">
      <span class="pc-box-card__icon">🧢</span>
      <span class="pc-box-card__eyebrow">Save file</span>
      <strong>Trainer Card</strong>
      <small>About me, favourite games, memories, milestones, and trainer vibes.</small>
    </a>

    <a class="pc-box-card pc-box-card--shiny" href="/shrines/pokemon/shinies/">
      <span class="pc-box-card__icon">✨</span>
      <span class="pc-box-card__eyebrow">Storage box</span>
      <strong>Shiny Shrine</strong>
      <small>My shiny catches, recent sparkles, Pokémon GO, and Safari Week finds.</small>
    </a>

    <a class="pc-box-card pc-box-card--records" href="/shrines/pokemon/records/">
      <span class="pc-box-card__icon">📜</span>
      <span class="pc-box-card__eyebrow">Save awards</span>
      <strong>Records</strong>
      <small>Diplomas, shiny starter milestones, certificates, ribbons, and achievement screenshots.</small>
    </a>

    <a class="pc-box-card pc-box-card--physical" href="/shrines/pokemon/physical/">
      <span class="pc-box-card__icon">📦</span>
      <span class="pc-box-card__eyebrow">PokéMart shelf</span>
      <strong>Physical Collection</strong>
      <small>Figures, games, cards, plushies, trinkets, and little Pokémon treasures.</small>
    </a>

    <a class="pc-box-card pc-box-card--hof" href="/shrines/pokemon/hof/">
      <span class="pc-box-card__icon">🏆</span>
      <span class="pc-box-card__eyebrow">League records</span>
      <strong>Hall of Fame</strong>
      <small>Champion teams, playthrough notes, MVPs, and completed adventures.</small>
    </a>
  </div>
</section>

{% if pokemonShinies.recent and pokemonShinies.recent.length %}
<section class="pc-section pc-section--recent">
  <div class="pc-section__heading">
    <p class="pc-kicker">Recent activity</p>
    <h2>Newest shinies</h2>
  </div>

  <div class="pc-mini-shiny-grid">
    {% for shiny in pokemonShinies.recent %}
      {% if loop.index <= 4 %}
        <a class="pc-mini-shiny" href="/shrines/pokemon/shinies/">
          {% if shiny.image %}
            <img src="{{ shiny.image }}" alt="Shiny {{ shiny.species }}">
          {% endif %}
          <span>#{{ shiny.dexNo }}</span>
          <strong>{{ shiny.nickname or shiny.species }}</strong>
          <small>{{ shiny.originGame }}</small>
        </a>
      {% endif %}
    {% endfor %}
  </div>
</section>
{% endif %}

<section class="pc-note">
  <p>
    <strong>System note:</strong> this shrine is being upgraded into a cuter PC-style hub.
    Older pages may get a glow-up as they are moved into the new layout.
  </p>
</section>
