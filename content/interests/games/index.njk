---
title: "Game Collection"
layout: layouts/gamesBase.njk
permalink: /games/
pageClass: games-index
customcss:
  - /assets/css/games/index.css
---

<p class="platform-intro">pick a platform to browse my lil game shelf 🐸✨</p>

<div class="platform-grid">
  {% for p in gamesOwned.platforms %}

    {% set icon = "🎮" %}

    {% if p.platform == "Nintendo 3DS" %}{% set icon = "🧩" %}{% endif %}
    {% if p.platform == "Nintendo DS" %}{% set icon = "📟" %}{% endif %}
    {% if p.platform == "Nintendo Game Boy Advance" %}{% set icon = "🟪" %}{% endif %}
    {% if p.platform == "Nintendo Switch" %}{% set icon = "🍄" %}{% endif %}
    {% if p.platform == "Nintendo Switch 2" %}{% set icon = "✨" %}{% endif %}
    {% if p.platform == "Nintendo Wii" %}{% set icon = "🎾" %}{% endif %}
    {% if p.platform == "Nintendo Wii U" %}{% set icon = "🔵" %}{% endif %}

    {% if p.platform == "PC" %}{% set icon = "🖥️" %}{% endif %}

    {% if p.platform == "Sony PlayStation" %}{% set icon = "⬜" %}{% endif %}
    {% if p.platform == "Sony PlayStation 2" %}{% set icon = "💿" %}{% endif %}
    {% if p.platform == "Sony PlayStation 3" %}{% set icon = "🔷" %}{% endif %}
    {% if p.platform == "Sony PlayStation 4" %}{% set icon = "🟦" %}{% endif %}
    {% if p.platform == "Sony PlayStation 5" %}{% set icon = "🖤" %}{% endif %}
    {% if p.platform == "Sony PS Vita" or p.platform == "PlayStation Vita" or p.platform == "Sony PlayStation Vita" %}{% set icon = "💜" %}{% endif %}

    <a class="platform-card" href="/games/{{ p.slug }}/">
      <div class="platform-icon" aria-hidden="true">{{ icon }}</div>

      <div class="platform-main">
        <span class="platform-name">{{ p.platform }}</span>
        <span class="platform-count">{{ p.games | length }} games</span>
      </div>

      <span class="platform-arrow" aria-hidden="true">↗</span>
    </a>

  {% endfor %}
</div>

{% if gamesOwned.attribution %}
  <p class="platform-attrib">
    <a href="{{ gamesOwned.attribution.url }}" target="_blank" rel="noopener">
      {{ gamesOwned.attribution.label }}
    </a>
  </p>
{% endif %}
