---
pagination:
  data: gamesOwned.platforms
  size: 1
  alias: platform

permalink: /games/{{ platform.slug }}/
layout: layouts/gamesBase.njk
pageClass: games-platform
customcss:
  - /assets/css/games/platform.css
---

<h2>{{ platform.platform }}</h2>
<p class="platform-subhead">press start to browse 🕹️</p>

<div class="games-grid">
  {% for game in platform.games %}
    {% set cover = game.image or "/assets/imgs/frog-placeholder.png" %}
    {% set pubs = game.publishers | default([]) %}
    {% set pubsText = pubs | join(", ") %}
    {% set gameUrl = game.sourceUrl or game.gamesDbUrl %}

    {% if gameUrl %}
      <a class="game-card"
         href="{{ gameUrl }}"
         target="_blank"
         rel="noopener"
         referrerpolicy="no-referrer">
    {% else %}
      <article class="game-card">
    {% endif %}

      <img src="{{ cover }}" alt="{{ game.title }}" loading="lazy">

      <h3>{{ game.title }}</h3>

      <p class="meta">
        {% if game.year %}{{ game.year }}{% endif %}
        {% if game.year and pubsText %} • {% endif %}
        {% if pubsText %}{{ pubsText }}{% endif %}
      </p>

      <div class="game-badges">
        {% if game.format %}
          <span class="game-badge game-badge--{{ game.formatSlug }}">{{ game.format }}</span>
        {% endif %}

        {% if game.storefront %}
          <span class="game-badge">{{ game.storefront }}</span>
        {% endif %}

        {% if game.edition %}
          <span class="game-badge">{{ game.edition }}</span>
        {% endif %}

        {% if game.region %}
          <span class="game-badge">{{ game.region }}</span>
        {% endif %}
      </div>

    {% if gameUrl %}
      </a>
    {% else %}
      </article>
    {% endif %}
  {% endfor %}
</div>

<div class="platform-footer">
  <a class="platform-back" href="/games/"> back to platforms</a>

  {% if gamesOwned.attribution %}
    <p class="platform-attrib">
      <a href="{{ gamesOwned.attribution.url }}" target="_blank" rel="noopener">
        {{ gamesOwned.attribution.label }}
      </a>
    </p>
  {% endif %}
</div>
