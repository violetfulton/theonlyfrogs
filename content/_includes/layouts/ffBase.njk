<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>{{ title or "Final Fantasy XIV" }} | TheOnlyFrogs</title>
  <meta name="viewport" content="width=device-width, initial-scale=1.0">

  <meta name="description" content="{{ description or 'A dreamy Final Fantasy XIV shrine on TheOnlyFrogs.' }}">
  <meta name="theme-color" content="#f7b3db">

  <link rel="stylesheet" href="/assets/css/ffxiv/ffxiv-base.css">

  {% if customcss %}
    <link rel="stylesheet" href="{{ customcss }}">
  {% endif %}

  {% if extraCss %}
    {% for sheet in extraCss %}
      <link rel="stylesheet" href="{{ sheet }}">
    {% endfor %}
  {% endif %}

  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Gaegu:wght@400;700&family=Quicksand:wght@400;500;700&display=swap" rel="stylesheet">
</head>

<body class="ff-body">
  <div class="ff-bg-stars" aria-hidden="true"></div>
  <div class="ff-bg-glow ff-bg-glow--left" aria-hidden="true"></div>
  <div class="ff-bg-glow ff-bg-glow--right" aria-hidden="true"></div>

  {% set currentUrl = page.url or "/" %}

{% set navItems = [
  { label: "Home", href: "/shrines/finalfantasyxiv/", match: "exact" },
  { label: "Achievements", href: "/shrines/finalfantasyxiv/achievements/", match: "prefix" },
  { label: "Checklist", href: "/shrines/finalfantasyxiv/checklist/", match: "prefix" },
  { label: "Housing", href: "/shrines/finalfantasyxiv/housing/", match: "prefix" },
  { label: "Glams", href: "/shrines/finalfantasyxiv/glams/", match: "prefix" },
  { label: "Gil", href: "/shrines/finalfantasyxiv/gil/", match: "prefix" },
  { label: "All Shrines", href: "/shrines/", match: "exact" },
  { label: "Site Home", href: "/", match: "exact" }
] %}

  <div class="ff-shell">
    <header class="ff-header">
      <div class="ff-header__inner">
        <a href="/shrines/finalfantasyxiv/" class="ff-title-wrap">
          <span class="ff-title-kicker">✦ the crystal archives ✦</span>
          <h1 class="ff-site-title">{{ shrineTitle or "Final Fantasy XIV Shrine" }}</h1>
          <p class="ff-site-subtitle">{{ shrineSubtitle or "moogles, pink sparkles, and little eorzean progress logs ♡" }}</p>
        </a>

        <div class="ff-header__mascots" aria-hidden="true">
          <span class="ff-pom"></span>
          <span class="ff-axolotl">◕ ◕</span>
        </div>
      </div>
    </header>

    <nav class="ff-nav" aria-label="Final Fantasy XIV shrine navigation">
      {% for item in navItems %}
        {% set isActive = false %}

        {% if item.match == "prefix" %}
          {% if currentUrl.startsWith(item.href) %}
            {% set isActive = true %}
          {% endif %}
        {% else %}
          {% if currentUrl == item.href %}
            {% set isActive = true %}
          {% endif %}
        {% endif %}

        <a
          href="{{ item.href }}"
          class="{% if isActive %}is-active{% endif %}"
          {% if isActive %}aria-current="page"{% endif %}
        >
          {{ item.label }}
        </a>
      {% endfor %}
    </nav>

    {% if intro %}
      <section class="ff-intro-card">
        {{ intro | safe }}
      </section>
    {% endif %}

    <main class="ff-main">
      {{ content | safe }}
    </main>

    <footer class="ff-footer">
      <p>✨ wandering Eorzea one cute little goal at a time ✨</p>
    </footer>
  </div>

  {% if pageScripts %}
    {% for script in pageScripts %}
      <script src="{{ script }}"></script>
    {% endfor %}
  {% endif %}
</body>
</html>