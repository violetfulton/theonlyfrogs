<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ title or "Pokémon Shrine" }}</title>

  <!-- shared shrine styles -->
  <link rel="stylesheet" href="/assets/css/shrines/pokemon/shared.css">

  <!-- page-specific CSS (string or array) -->
  {% if customcss %}
    {% if customcss | length and (customcss is not string) %}
      {% for href in customcss %}
        <link rel="stylesheet" href="{{ href }}">
      {% endfor %}
    {% else %}
      <link rel="stylesheet" href="{{ customcss }}">
    {% endif %}
  {% endif %}

  <link href="https://fonts.googleapis.com/css2?family=Press+Start+2P&display=swap" rel="stylesheet">
</head>
<body>

  <!-- 🌿 PokéNav (top-left) -->
  <nav class="pokenav" aria-label="Pokémon shrine navigation">
    <button class="pokenav__toggle"
            type="button"
            aria-expanded="false"
            aria-controls="pokenavPanel">
      PokéNav
    </button>

    <div class="pokenav__panel" id="pokenavPanel">
      <div class="pokenav__header">
        <div class="pokenav__title">VIOLET's PC</div>
        <div class="pokenav__sub">shrine storage system</div>
      </div>

{% set current = page.url %}

<div class="pokenav__links">
  <a class="pokenav__link {% if current == '/shrines/pokemon/' %}is-active{% endif %}"
     href="/shrines/pokemon/">🏠 Home</a>

  <a class="pokenav__link {% if current == '/shrines/pokemon/me/' %}is-active{% endif %}"
     href="/shrines/pokemon/me/">🧢 Trainer</a>

  <a class="pokenav__link {% if current == '/shrines/pokemon/shinies/' or '/shrines/pokemon/shinies/' in current %}is-active{% endif %}"
     href="/shrines/pokemon/shinies/">✨ Shinies</a>

  <a class="pokenav__link {% if current == '/shrines/pokemon/records/' %}is-active{% endif %}"
     href="/shrines/pokemon/records/">📜 Records</a>

  <a class="pokenav__link {% if current == '/shrines/pokemon/physical/' %}is-active{% endif %}"
     href="/shrines/pokemon/physical/">📦 Physical</a>

  <a class="pokenav__link {% if current == '/shrines/pokemon/hof/' %}is-active{% endif %}"
     href="/shrines/pokemon/hof/">🏆 Hall of Fame</a>

  <a class="pokenav__link pokenav__link--minor {% if current == '/' %}is-active{% endif %}"
     href="/">↩ Main Site</a>
</div>
    </div>
  </nav>

  <div class="pokenav__backdrop" hidden></div>

  <main class="poke-shell">
    {{ content | safe }}
  </main>

<script src="/assets/js/pokemon/shared.js"></script>
</body>
</html>