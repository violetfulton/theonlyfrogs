<section class="trakt-section">
  <div class="trakt-widget">
    <h3>
      <a href="https://simkl.com/8313205/"
         target="_blank" rel="noopener">
        📺 Simkl
      </a>
    </h3>
    <p class="trakt-subtitle">current show + last 3 movies</p>

    {# --- Current show (1 item) --- #}
    {% if simklNow.show %}
      <div class="trakt-current-card">
        <a href="{{ simklNow.show.url }}" target="_blank" rel="noopener">
          <div class="trakt-current-img">
            <img src="{{ simklNow.show.poster }}" alt="{{ simklNow.show.title }}" loading="lazy">
            {% if simklNow.show.pill %}
              <span class="trakt-pill">{{ simklNow.show.pill }}</span>
            {% endif %}
          </div>

          <div class="trakt-current-info">
            <h4>{{ simklNow.show.title }}</h4>
            <p class="trakt-meta">
              {% if simklNow.show.year %}{{ simklNow.show.year }} · {% endif %}
              <span class="trakt-stars">{{ simklNow.show.stars }}</span>
            </p>

            {% if simklNow.show.subtitle %}
              <p class="trakt-episode-title">{{ simklNow.show.subtitle }}</p>
            {% endif %}
          </div>
        </a>
      </div>
    {% endif %}

    {# --- Last 3 movies --- #}
    {% if simklNow.movies and simklNow.movies.length %}
      <div class="trakt-movies">
        {% for item in simklNow.movies %}
          <div class="trakt-movie">
            <a href="{{ item.url }}" target="_blank" rel="noopener">
              <img class="trakt-movie-thumb" src="{{ item.poster }}" alt="{{ item.title }}" loading="lazy">
              <div class="trakt-movie-meta">
                <span class="trakt-movie-title">{{ item.title }}</span>
                <span class="trakt-movie-sub">
                  {% if item.year %}{{ item.year }} · {% endif %}
                  {{ item.stars }}
                </span>
              </div>
            </a>
          </div>
        {% endfor %}
      </div>
    {% else %}
      <p class="trakt-empty">no recent movies found :(</p>
    {% endif %}
  </div>
</section>